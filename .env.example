# ──────────────────────────────────────────────────────────────────────────────
# .env.example → .env 으로 복사 후 값을 채워주세요
# cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# ── 프로바이더 키 ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
# ANTHROPIC_API_KEY=                      # Anthropic 모델 사용 시
# GOOGLE_API_KEY=                         # Google 모델 사용 시 (선택)

# ── 기본 LLM 모델 ──────────────────────────────────────────────────────────────
# 그래프 내부에서 create_llm() 기본값으로 사용되는 모델
DEFAULT_LLM_MODEL=gpt-4o-mini

# ── 백엔드 API 인증 키 ────────────────────────────────────────────────────────
# OpenWebUI가 백엔드 호출 시 사용하는 Bearer 토큰
API_KEY=sk-langgraph-local

# ── 패스스루 모델 목록 ─────────────────────────────────────────────────────────
# OpenWebUI 모델 선택에 노출할 프로바이더 모델 (쉼표 구분)
# 이 모델들은 LangGraph 없이 프로바이더로 직접 전달됩니다
EXTRA_MODELS=gpt-4o,gpt-4o-mini

# ── LangSmith (선택: 워크플로우 추적) ────────────────────────────────────────
# https://smith.langchain.com 에서 키 발급
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=langgraph-openwebui

# ── Tavily 검색 API (assistant-research 툴) ───────────────────────────────────
# https://app.tavily.com 에서 키 발급
TAVILY_API_KEY=

# ── OpenWebUI 설정 ────────────────────────────────────────────────────────────
WEBUI_SECRET_KEY=change-me-in-production-random-32-char
WEBUI_AUTH=false  # 프로덕션에서는 true

# ── 요청 타임아웃 (초) ────────────────────────────────────────────────────────
REQUEST_TIMEOUT=60
